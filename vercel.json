{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix frontend install",
  "buildCommand": "npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/host",
      "destination": "/index.html"
    },
    {
      "source": "/join",
      "destination": "/index.html"
    },
    {
      "source": "/join/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/session/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/listen/:path*",
      "destination": "/index.html"
    }
  ]
}
