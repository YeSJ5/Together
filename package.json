{
  "name": "together-local-suite",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm --prefix backend install && npm --prefix frontend install",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run build && npm --prefix backend start",
    "start:backend": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "android:build": "npm --prefix frontend run android:build",
    "android:sync": "npm --prefix frontend run cap:sync",
    "android:open": "npm --prefix frontend run cap:open"
  }
}
